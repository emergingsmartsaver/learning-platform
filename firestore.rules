rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Content collections: public read, writes only via Admin SDK (seed scripts).
    match /careerPaths/{doc} { allow read: if true; allow write: if false; }
    match /stages/{doc}      { allow read: if true; allow write: if false; }
    match /milestones/{doc}  { allow read: if true; allow write: if false; }
    match /skills/{doc}      { allow read: if true; allow write: if false; }
    match /quizzes/{doc}     { allow read: if true; allow write: if false; }
    match /projects/{doc}    { allow read: if true; allow write: if false; }

    // User-owned collections.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /progress/{docId} {
      allow read, write: if request.auth != null && docId.matches(request.auth.uid + '_.*');
    }
    match /quizAttempts/{docId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /projectProgress/{docId} {
      allow read, write: if request.auth != null && docId.matches(request.auth.uid + '_.*');
    }
  }
}
