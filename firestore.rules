rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Content collections: public read, writes only via Admin SDK (seed scripts).
    match /careerPaths/{doc} { allow read: if true; allow write: if false; }
    match /stages/{doc}      { allow read: if true; allow write: if false; }
    match /milestones/{doc}  { allow read: if true; allow write: if false; }
    match /skills/{doc}      { allow read: if true; allow write: if false; }
    match /quizzes/{doc}     { allow read: if true; allow write: if false; }
    match /projects/{doc}    { allow read: if true; allow write: if false; }

    // User-owned collections.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // These use resource.data.uid (a stored field) rather than a docId
    // pattern check — Firestore can only verify a list/query request is
    // safe when the rule checks a field that matches the query's `where`
    // filter. An ID-pattern rule works for a direct get() by known ID, but
    // is rejected outright for any collection query, even one that would
    // only ever return the caller's own documents.
    match /progress/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
    match /quizAttempts/{docId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
    match /projectProgress/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
